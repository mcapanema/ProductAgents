# ProductAgents connector configuration.
# Copy to connectors.yaml (or set PRODUCTAGENTS_CONNECTORS_FILE) and edit.
# Secrets are referenced by env var via a `<field>_env` key — never inline tokens.
connectors:
  github:
    enabled: true
    owner: your-org
    repo: your-repo
    token_env: GITHUB_TOKEN   # reads $GITHUB_TOKEN at sync time
  jira:
    enabled: true
    base_url: https://your-site.atlassian.net
    email: you@your-org.com
    token_env: JIRA_API_TOKEN  # reads $JIRA_API_TOKEN at sync time
    project: PROJ              # optional: limit to one project key
