{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ProductAgents",
  "version": "0.1.0",
  "identifier": "com.productagents.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      { "title": "ProductAgents", "width": 1200, "height": 800 }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/productagents-ipc"],
    "publisher": "ProductAgents",
    "copyright": "Copyright © 2026 ProductAgents",
    "category": "Productivity",
    "shortDescription": "A local operating environment for product decision-making.",
    "longDescription": "ProductAgents is a local-first desktop environment that runs multi-agent product decision workflows — evidence gathering, debate, strategy, risk, and governance — entirely on your machine. No account, no cloud.",
    "homepage": "https://github.com/mcapanema/ProductAgents"
  }
}
