Screen {
    layout: vertical;
}

#initiative-title {
    dock: top;
    margin: 1 1 0 1;
}

#analysts {
    height: auto;
}

.panel {
    border: round $primary;
    padding: 1;
    margin: 1;
    height: auto;
}

#debate-scroll {
    height: 1fr;
    margin: 1;
    border: round $accent;
}

#debate {
    padding: 1;
}

#strategist {
    border: round $success;
    height: auto;
}

#risk-scroll {
    height: 1fr;
    margin: 1;
    border: round $warning;
}

#risk {
    padding: 1;
}

#governance {
    border: round $secondary;
    height: auto;
}
