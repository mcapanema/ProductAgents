Screen {
    layout: vertical;
}

#top-bar {
    dock: top;
    height: auto;
    margin: 1 1 0 1;
}

#initiative-title {
    width: 2fr;
}

#evidence-source {
    width: 3fr;
    margin-left: 1;
}

#lanes {
    height: 1fr;
}

#left-lane {
    width: 26%;
}

#center-lane {
    width: 1fr;
}

#right-lane {
    width: 32%;
}

#analyst-grid {
    grid-size: 3 2;
    grid-gutter: 1;
    height: 2fr;
}

.analyst {
    height: 100%;
    overflow-y: auto;
    border: round #38bdf8;
}

.panel {
    border: round $primary;
    padding: 1;
    margin: 1;
    height: auto;
}

#debate-scroll {
    height: 1fr;
    margin: 1;
    border: round #f59e0b;
}

#debate {
    padding: 1;
}

#strategist {
    border: round #22c55e;   /* strategy — green */
    height: auto;
}

#risk-scroll {
    height: 1fr;
    margin: 1;
    border: round #fb923c;
}

#risk {
    padding: 1;
}

#governance {
    border: round #a78bfa;   /* governance — violet */
    height: auto;
}

#decision-list {
    height: auto;
    max-height: 10;
    margin: 1;
    border: round $primary;
}

#outcome-note {
    margin: 1;
}

#reflection {
    border: round $accent;
    padding: 1;
    margin: 1;
    height: auto;
}

#home-status {
    margin: 1;
    border: round $primary;
    padding: 1;
    height: auto;
}

#home-setup, #home-run, #home-quit {
    margin: 0 1;
    width: 100%;
}

SetupScreen {
    align: center middle;
}

#setup-intro {
    margin: 1;
    padding: 1;
    border: round $warning;
    height: auto;
}

#setup-provider, #setup-model, #setup-key {
    margin: 0 1;
}

#setup-key-label {
    margin: 1 1 0 1;
    color: $text-muted;
}

#setup-feedback {
    margin: 1;
    color: $error;
    height: auto;
}

#setup-save, #setup-cancel {
    margin: 0 1;
}

#status-log {
    dock: bottom;
    height: 8;
    margin: 0 1 1 1;
    border: round $error;
    padding: 0 1;
    overflow-y: auto;
}

.failed {
    border: round $error;
}

/* Per-stage accent borders are inlined above; .failed overrides all via CSS class. */
#recall, #evidence-provenance {
    border: round $primary;
}
