Screen {
    layout: vertical;
    background: $background;
    color: $ink;
}

/* ---- command bar ---------------------------------------------------- */
#top-bar {
    dock: top;
    height: auto;
    margin: 1 1 0 1;
}

#initiative-title {
    width: 3fr;
}

#evidence-source {
    width: 2fr;
    margin-left: 1;
}

/* ---- lanes ---------------------------------------------------------- */
#lanes {
    height: 1fr;
}

#left-lane {
    width: 26%;
}

#center-lane {
    width: 1fr;
}

#right-lane {
    width: 32%;
}

#analyst-grid {
    grid-size: 3 2;
    grid-gutter: 1;
    height: 2fr;
}

/* ---- panels: a queued panel recedes; stage hue is added on activity - */
.panel {
    border: round $idle-border;
    background: $panel;
    color: $ink;
    padding: 1;
    margin: 1;
    height: auto;
}

.panel.-active {
    border: round $primary;
}

.panel.-done {
    border: round $primary;
}

.analyst {
    height: 100%;
    overflow-y: auto;
    border: round $idle-border;
}

.analyst.-active,
.analyst.-done {
    border: round $stage-analysis;
}

#evidence-provenance.-active,
#evidence-provenance.-done {
    border: round $stage-evidence;
}

#recall.-active,
#recall.-done {
    border: round $stage-recall;
}

#debate-scroll {
    height: 1fr;
    margin: 1;
    border: round $idle-border;
}

#debate-scroll.-active,
#debate-scroll.-done {
    border: round $stage-debate;
}

#debate {
    padding: 1;
}

#strategist {
    border: round $idle-border;
    height: 1fr;
    overflow-y: auto;
}

#strategist.-active,
#strategist.-done {
    border: round $stage-strategy;
}

#judgment {
    height: 1fr;
    overflow-y: auto;
    border: round $idle-border;
}

#judgment.-active,
#judgment.-done {
    border: round $stage-judge;
}

#risk-scroll {
    height: 1fr;
    margin: 1;
    border: round $idle-border;
}

#risk-scroll.-active,
#risk-scroll.-done {
    border: round $stage-risk;
}

#risk {
    padding: 1;
}

#governance {
    border: round $idle-border;
    height: 1fr;
    overflow-y: auto;
}

#governance.-active,
#governance.-done {
    border: round $stage-governance;
}

/* ---- status: quiet unless it has something to say ------------------- */
#status-log {
    dock: bottom;
    height: 8;
    margin: 0 1 1 1;
    border: round $idle-border;
    padding: 0 1;
    overflow-y: auto;
}

/* ---- state overrides win over stage hues ---------------------------- */
.failed {
    border: round $error;
}

.warning {
    border: round $warning;
}

/* ---- modal / secondary screens (inherit theme vars) ----------------- */
#decision-list {
    height: auto;
    max-height: 10;
    margin: 1;
    border: round $primary;
}

#outcome-note {
    margin: 1;
}

#reflection {
    border: round $accent;
    padding: 1;
    margin: 1;
    height: auto;
}

#home-status {
    margin: 1;
    border: round $primary;
    padding: 1;
    height: auto;
}

#home-setup, #home-run, #home-quit {
    margin: 0 1;
    width: 100%;
}

SetupScreen {
    align: center middle;
}

#setup-intro {
    margin: 1;
    padding: 1;
    border: round $warning;
    height: auto;
}

#setup-provider, #setup-model, #setup-key {
    margin: 0 1;
}

#setup-key-label {
    margin: 1 1 0 1;
    color: $muted;
}

#setup-feedback {
    margin: 1;
    color: $error;
    height: auto;
}

#setup-save, #setup-cancel {
    margin: 0 1;
}
